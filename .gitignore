# ─────────────────────────────────────────────
#  JobPilot AI — .gitignore
# ─────────────────────────────────────────────

# ── Environment files (NEVER commit these) ────
.env
.env.local
.env.production
.env.staging
.env.*.local
**/.env
**/.env.local
**/.env.production

# ── Node.js ───────────────────────────────────
node_modules/
**/node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/
package-lock.json
yarn.lock

# ── Next.js ───────────────────────────────────
frontend/.next/
frontend/out/
frontend/.vercel/
frontend/next-env.d.ts

# ── TypeScript compiled output ────────────────
dist/
build/
*.tsbuildinfo

# ── Python ────────────────────────────────────
__pycache__/
**/__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
env/
.venv/
ENV/
*.egg-info/
.eggs/
*.egg
pip-log.txt
pip-delete-this-directory.txt
.pytest_cache/
.coverage
htmlcov/
.tox/
.mypy_cache/
.dmypy.json

# ── Django ────────────────────────────────────
django/staticfiles/
django/media/
django/db.sqlite3
*.sqlite3

# ── Celery ────────────────────────────────────
celerybeat-schedule
celerybeat.pid
celery-worker.pid

# ── Playwright / Scraper ──────────────────────
scraper/cookies/
playwright-report/
test-results/

# ── Docker ────────────────────────────────────
.docker/

# ── Logs ──────────────────────────────────────
logs/
*.log
*.log.*

# ── OS files ──────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ── IDE / Editor ──────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.history/

# ── SSH Keys (just in case) ───────────────────
*.pem
*.key
*.p12
*.pfx

# ── Misc ──────────────────────────────────────
.cache/
tmp/
temp/
coverage/
.nyc_output/