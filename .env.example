# ─────────────────────────────────────────────────────────────
#  JobPilot AI — Environment Variables Template
#  Copy to .env and fill in your values.
#  NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────

# ── Django ────────────────────────────────────────────────────
DJANGO_SECRET_KEY=your-django-secret-key-here
DEBUG=true

# ── JWT (Express Gateway) ─────────────────────────────────────
JWT_SECRET=your-jwt-secret-min-32-chars

# ── AI APIs ───────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# ── HR Finder APIs ────────────────────────────────────────────
APOLLO_API_KEY=your-apollo-key
HUNTER_API_KEY=your-hunter-key

# ── Email ─────────────────────────────────────────────────────
SENDGRID_API_KEY=SG....
EMAIL_FROM=noreply@jobpilot.ai

# ── Notifications (optional) ──────────────────────────────────
SLACK_BOT_TOKEN=xoxb-...
SLACK_CHANNEL_ID=C...
TELEGRAM_BOT_TOKEN=...
TELEGRAM_CHAT_ID=...

# ── Scraper ───────────────────────────────────────────────────
LINKEDIN_COOKIE_FILE=/scraper/cookies/linkedin.json
SEARCH_KEYWORDS=Senior Backend Engineer,Staff Engineer,Principal Engineer
SEARCH_LOCATIONS=Bengaluru,Mumbai,Remote
EXPERIENCE_YEARS=6
MAX_PAGES=5
HEADLESS=true
SCRAPER_API_KEY=dev-scraper-key-change-in-prod

# ── Database (auto-configured in Docker — only override if external) ──
# DATABASE_URL=postgres://jobpilot:jobpilot@localhost:5432/jobpilot
# REDIS_URL=redis://localhost:6379/0
# ELASTICSEARCH_URL=http://localhost:9200
